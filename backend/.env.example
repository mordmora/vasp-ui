# Configuración del Cluster SSH
CLUSTER_HOST=your-cluster-hostname.edu
CLUSTER_PORT=22
CLUSTER_USER=your-username
CLUSTER_PASSWORD=your-password
# O usar llave SSH (recomendado):
CLUSTER_SSH_KEY_PATH=/path/to/your/private/key

# Rutas en el cluster
CLUSTER_VASP_PATH=/path/to/vasp/executable
CLUSTER_VASPKIT_PATH=/path/to/vaspkit
CLUSTER_POTCAR_PATH=/path/to/potcar/directory
CLUSTER_WORK_DIR=/home/username/vasp_calculations

# Base de datos local
DATABASE_URL=sqlite+aiosqlite:///./vasp_gui.db

# Configuración de la aplicación
SECRET_KEY=your-secret-key-here-change-in-production
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# Configuración de monitoreo
JOB_CHECK_INTERVAL=30  # segundos entre verificaciones de estado
